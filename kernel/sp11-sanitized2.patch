 	cpu_node = of_cpu_device_node_get(cpu);
@@ -409,6 +410,19 @@ static int psci_idle_init_cpu(struct device *dev, int cpu)
 		return ret;
 	}
 
+	/*
+	 * Surface Pro 11 can hard-lock when the Denali PSCI retention state
+	 * races a display/RPMh resource transition.  Keep the CPUIdle framework
+	 * and architectural WFI state, but default every firmware-managed state
+	 * to off before this per-CPU driver is registered.
+	 */
+	if (of_machine_is_compatible("microsoft,denali")) {
+		for (i = 1; i < drv->state_count; i++)
+			drv->states[i].flags |= CPUIDLE_FLAG_OFF;
+
+		pr_info_once("Surface Pro 11: PSCI non-WFI states disabled by default\n");
+	}
+
 	ret = cpuidle_register(drv, NULL);
 	if (ret)
 		goto deinit;
diff --git a/drivers/dma/qcom/gpi.c b/drivers/dma/qcom/gpi.c
