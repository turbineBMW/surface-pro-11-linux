From d80d6c31e488be3c296649728c83e76869dc60cd Mon Sep 17 00:00:00 2001
From: turbinebmw <turbine.bmw@gmail.com>
Date: Sun, 19 Jul 2026 17:32:14 -0400
Subject: [PATCH 01/13] dt-bindings: media: qcom,x1e80100-camss: correct
 resources

Describe the five current HLOS CAMSS IOMMU stream IDs while retaining
the legacy eight-entry form. Correct the CSIPHY0-2 register sizes in the
example.

The IOMMU description is adapted from Bryan O'Donoghue's X1E80100 CAMSS
binding work.
---
 .../bindings/media/qcom,x1e80100-camss.yaml   | 32 +++++++++++++------
 1 file changed, 22 insertions(+), 10 deletions(-)

diff --git a/Documentation/devicetree/bindings/media/qcom,x1e80100-camss.yaml b/Documentation/devicetree/bindings/media/qcom,x1e80100-camss.yaml
index 2d1662ef5..534b3c810 100644
--- a/Documentation/devicetree/bindings/media/qcom,x1e80100-camss.yaml
+++ b/Documentation/devicetree/bindings/media/qcom,x1e80100-camss.yaml
@@ -104,7 +104,22 @@ properties:
       - const: sf_icp_mnoc
 
   iommus:
-    maxItems: 8
+    oneOf:
+      - items:
+          - description: S1 HLOS IFE and IFE_LITE non-protected read
+          - description: S1 HLOS IFE and IFE_LITE non-protected write
+          - description: S1 HLOS SFE non-protected read
+          - description: S1 HLOS SFE non-protected write
+          - description: S1 HLOS CDM IFE non-protected
+          - description: Legacy slot 0 - do not use
+          - description: Legacy slot 1 - do not use
+          - description: Legacy slot 2 - do not use
+      - items:
+          - description: S1 HLOS IFE and IFE_LITE non-protected read
+          - description: S1 HLOS IFE and IFE_LITE non-protected write
+          - description: S1 HLOS SFE non-protected read
+          - description: S1 HLOS SFE non-protected write
+          - description: S1 HLOS CDM IFE non-protected
 
   power-domains:
     items:
@@ -199,9 +214,9 @@ examples:
                   <0 0x0acc6000 0 0x1000>,
                   <0 0x0acca000 0 0x1000>,
                   <0 0x0acb6000 0 0x1000>,
-                  <0 0x0ace4000 0 0x1000>,
-                  <0 0x0ace6000 0 0x1000>,
-                  <0 0x0ace8000 0 0x1000>,
+                  <0 0x0ace4000 0 0x2000>,
+                  <0 0x0ace6000 0 0x2000>,
+                  <0 0x0ace8000 0 0x2000>,
                   <0 0x0acec000 0 0x4000>,
                   <0 0x0acf6000 0 0x1000>,
                   <0 0x0acf7000 0 0x1000>,
@@ -332,13 +347,10 @@ examples:
                                  "sf_icp_mnoc";
 
             iommus = <&apps_smmu 0x800 0x60>,
+                     <&apps_smmu 0x820 0x60>,
+                     <&apps_smmu 0x840 0x60>,
                      <&apps_smmu 0x860 0x60>,
-                     <&apps_smmu 0x1800 0x60>,
-                     <&apps_smmu 0x1860 0x60>,
-                     <&apps_smmu 0x18e0 0x00>,
-                     <&apps_smmu 0x1980 0x20>,
-                     <&apps_smmu 0x1900 0x00>,
-                     <&apps_smmu 0x19a0 0x20>;
+                     <&apps_smmu 0x18a0 0x0>;
 
             power-domains = <&camcc CAM_CC_IFE_0_GDSC>,
                             <&camcc CAM_CC_IFE_1_GDSC>,

From 4b1b999efac1b05b354218f8a43d23bac72c8e68 Mon Sep 17 00:00:00 2001
From: turbinebmw <turbine.bmw@gmail.com>
Date: Sun, 19 Jul 2026 17:32:14 -0400
Subject: [PATCH 02/13] dt-bindings: media: add OV13858 and VD55G0 sensors

Document the power, clock, and CSI-2 connections used by the
OmniVision OV13858 and STMicroelectronics VD55G0 sensors.

The VD55G0 binding is adapted from STMicroelectronics
vd55g0-linux-driver revision:

  9134fe572b77f906344f37ba227f375db73dc026
---
 .../bindings/media/i2c/ovti,ov13858.yaml      | 114 +++++++++++++++
 .../bindings/media/i2c/st,vd55g0.yaml         | 135 ++++++++++++++++++
 2 files changed, 249 insertions(+)
 create mode 100644 Documentation/devicetree/bindings/media/i2c/ovti,ov13858.yaml
 create mode 100644 Documentation/devicetree/bindings/media/i2c/st,vd55g0.yaml

diff --git a/Documentation/devicetree/bindings/media/i2c/ovti,ov13858.yaml b/Documentation/devicetree/bindings/media/i2c/ovti,ov13858.yaml
new file mode 100644
index 000000000..7f146a016
--- /dev/null
+++ b/Documentation/devicetree/bindings/media/i2c/ovti,ov13858.yaml
@@ -0,0 +1,114 @@
+# SPDX-License-Identifier: (GPL-2.0-only OR BSD-2-Clause)
+%YAML 1.2
+---
+$id: http://devicetree.org/schemas/media/i2c/ovti,ov13858.yaml#
+$schema: http://devicetree.org/meta-schemas/core.yaml#
+
+title: Omnivision OV13858 CMOS Sensor
+
+maintainers:
+  - Sakari Ailus <sakari.ailus@linux.intel.com>
+
+description: |
+  The Omnivision OV13858 is a 13.2 megapixel, CMOS image sensor with an
+  active array size of 4224H x 3136V. It supports:
+  - Automatic black level calibration (BLC)
+  - Programmable controls for frame rate, mirror and flip, binning,
+    cropping and windowing
+  - Output format 10-bit Bayer RAW
+  - 4-lane MIPI D-PHY TX @ 1.08 Gbps per lane
+  - Standard SCCB command interface
+
+allOf:
+  - $ref: /schemas/media/video-interface-devices.yaml#
+
+properties:
+  compatible:
+    const: ovti,ov13858
+
+  reg:
+    maxItems: 1
+
+  clocks:
+    description: XVCLK external clock, 19.2 MHz.
+    maxItems: 1
+
+  avdd-supply:
+    description: Analogue circuit voltage supply.
+
+  dovdd-supply:
+    description: I/O circuit voltage supply.
+
+  dvdd-supply:
+    description: Digital circuit voltage supply.
+
+  reset-gpios:
+    description: Active low GPIO connected to XSHUTDOWN pad of the sensor.
+
+  port:
+    $ref: /schemas/graph.yaml#/$defs/port-base
+    additionalProperties: false
+
+    properties:
+      endpoint:
+        $ref: /schemas/media/video-interfaces.yaml#
+        additionalProperties: false
+
+        properties:
+          data-lanes:
+            items:
+              - const: 1
+              - const: 2
+              - const: 3
+              - const: 4
+          link-frequencies: true
+          remote-endpoint: true
+
+        required:
+          - data-lanes
+          - link-frequencies
+          - remote-endpoint
+
+required:
+  - compatible
+  - reg
+  - clocks
+  - port
+
+unevaluatedProperties: false
+
+examples:
+  - |
+    #include <dt-bindings/gpio/gpio.h>
+
+    i2c {
+        #address-cells = <1>;
+        #size-cells = <0>;
+
+        ov13858: camera@10 {
+            compatible = "ovti,ov13858";
+            reg = <0x10>;
+
+            reset-gpios = <&tlmm 110 GPIO_ACTIVE_LOW>;
+            pinctrl-names = "default";
+            pinctrl-0 = <&cam_rear_default>;
+
+            clocks = <&camcc_mclk1>;
+
+            assigned-clocks = <&camcc_mclk1>;
+            assigned-clock-rates = <19200000>;
+
+            avdd-supply = <&vreg_l5m_2p8>;
+            dvdd-supply = <&vreg_l1m_1p2>;
+            dovdd-supply = <&vreg_l6m_1p8>;
+
+            port {
+                ov13858_ep: endpoint {
+                    remote-endpoint = <&csiphy0_ep>;
+                    data-lanes = <1 2 3 4>;
+                    link-frequencies = /bits/ 64 <540000000 270000000>;
+                };
+            };
+        };
+    };
+...
diff --git a/Documentation/devicetree/bindings/media/i2c/st,vd55g0.yaml b/Documentation/devicetree/bindings/media/i2c/st,vd55g0.yaml
new file mode 100644
index 000000000..221c024ea
--- /dev/null
+++ b/Documentation/devicetree/bindings/media/i2c/st,vd55g0.yaml
@@ -0,0 +1,135 @@
+# SPDX-License-Identifier: (GPL-2.0-only OR BSD-2-Clause)
+# Copyright (c) 2022 STMicroelectronics SA.
+%YAML 1.2
+---
+$id: http://devicetree.org/schemas/media/i2c/st,vd55g0.yaml#
+$schema: http://devicetree.org/meta-schemas/core.yaml#
+
+title: STMicroelectronics VD55G0 HDR global-shutter image sensor
+
+maintainers:
+  - Benjamin Mugnier <benjamin.mugnier@foss.st.com>
+  - Sylvain Petinot <sylvain.petinot@foss.st.com>
+
+description: |
+  VD55G0 is a 644x604 global-shutter image sensor with a one- or two-lane
+  CSI-2 output. Supported formats are RAW8, RAW10, RAW12, RAW14 and RAW16.
+
+allOf:
+  - $ref: /schemas/media/video-interface-devices.yaml#
+
+properties:
+  compatible:
+    const: st,vd55g0
+
+  reg:
+    maxItems: 1
+
+  clocks:
+    maxItems: 1
+
+  VCORE-supply:
+    description:
+      Sensor digital core supply. Must be 1.2 volts.
+
+  VDDIO-supply:
+    description:
+      Sensor digital IO supply. Must be 1.8 volts.
+
+  VANA-supply:
+    description:
+      Sensor analog supply. Must be 2.8 volts.
+
+  reset-gpios:
+    description:
+      Reference to the GPIO connected to the reset pin, if any.
+      This is an active low signal to the vd55g0.
+    maxItems: 1
+
+  st,leds:
+    description:
+      Sensor LEDs GPIOs numbers to be used for illumination.
+    $ref: /schemas/types.yaml#/definitions/uint32-array
+    minItems: 1
+    maxItems: 4
+    items:
+      minimum: 0
+      maximum: 3
+
+  st,out-sync:
+    description:
+      Sensor GPIOs numbers to output a synchronisation signal, used in
+      conjonction with st,in-sync-gpios.
+    $ref: /schemas/types.yaml#/definitions/uint32-array
+    minItems: 1
+    maxItems: 4
+    items:
+      minimum: 0
+      maximum: 3
+
+  st,in-sync:
+    description:
+      Sensor GPIO number to trigger Slave mode. If present the sensor will
+      aquire frames only when a raising edge is received on this GPIO.
+    $ref: /schemas/types.yaml#/definitions/uint32
+    const: 0
+
+  port:
+    $ref: /schemas/graph.yaml#/$defs/port-base
+    additionalProperties: false
+
+    properties:
+      endpoint:
+        $ref: /schemas/media/video-interfaces.yaml#
+        unevaluatedProperties: false
+
+        properties:
+          data-lanes:
+            description:
+              CSI lanes to use
+            minItems: 1
+            maxItems: 2
+            items:
+              enum: [1, 2]
+
+          remote-endpoint: true
+
+        required:
+          - data-lanes
+
+required:
+  - compatible
+  - reg
+  - clocks
+  - VCORE-supply
+  - VDDIO-supply
+  - VANA-supply
+  - port
+
+unevaluatedProperties: false
+
+examples:
+  - |
+    #include <dt-bindings/gpio/gpio.h>
+    i2c {
+        #address-cells = <1>;
+        #size-cells = <0>;
+        vd55g0: csi2tx@10 {
+            compatible = "st,vd55g0";
+            reg = <0x10>;
+            clocks = <&clk_ext_camera>;
+            VCORE-supply = <&v1v2>;
+            VDDIO-supply = <&v1v8>;
+            VANA-supply = <&v2v8>;
+            reset-gpios = <&mfxgpio 18 GPIO_ACTIVE_LOW>;
+            st,leds = <0 1>;
+            st,out-sync = <2 3>;
+            port {
+                ep0: endpoint {
+                    data-lanes = <1 2>;
+                    remote-endpoint = <&mipi_csi2_out>;
+                };
+            };
+        };
+    };
+...

From 71a6d4fdb8f1b8292e9b096017813ad5c39f3744 Mon Sep 17 00:00:00 2001
