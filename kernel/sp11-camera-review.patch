From b95c77d2a512fd300f34d8309c1ce40c5c2fd895 Mon Sep 17 00:00:00 2001
From: turbinebmw <turbine.bmw@gmail.com>
Date: Sun, 19 Jul 2026 17:32:14 -0400
Subject: [PATCH 05/13] media: qcom: camss: unwind failed stream starts

Stop each subdevice that started successfully when a later pipeline
entity fails. Continue stopping the remaining subdevices after an
individual stop error.
---
 .../media/platform/qcom/camss/camss-video.c   | 58 +++++++++++--------
 1 file changed, 33 insertions(+), 25 deletions(-)

diff --git a/drivers/media/platform/qcom/camss/camss-video.c b/drivers/media/platform/qcom/camss/camss-video.c
index 831486e14..6b5985d2e 100644
--- a/drivers/media/platform/qcom/camss/camss-video.c
+++ b/drivers/media/platform/qcom/camss/camss-video.c
@@ -240,6 +240,35 @@ static int video_prepare_streaming(struct vb2_queue *q)
 	return ret;
 }
 
+static void video_stop_subdevices(struct camss_video *video,
+				  const struct media_entity *stop_entity)
+{
+	struct media_entity *entity = &video->vdev.entity;
+	struct media_pad *pad;
+	struct v4l2_subdev *subdev;
+	int ret;
+
+	while (1) {
+		pad = &entity->pads[0];
+		if (!(pad->flags & MEDIA_PAD_FL_SINK))
+			break;
+
+		pad = media_pad_remote_pad_first(pad);
+		if (!pad || !is_media_entity_v4l2_subdev(pad->entity))
+			break;
+
+		entity = pad->entity;
+		if (entity == stop_entity)
+			break;
+
+		subdev = media_entity_to_v4l2_subdev(entity);
