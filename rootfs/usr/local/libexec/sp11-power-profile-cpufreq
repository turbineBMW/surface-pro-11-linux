#!/usr/bin/python3
"""Apply a conservative SP11 CPU-frequency ceiling for low-power profile.

The SP11 Surface platform-profile driver exposes the real SAM/EC profile at
/sys/class/platform-profile/platform-profile-0/profile.  The firmware profile
does not currently impose an observable short-load CPU-frequency limit, so this
small companion applies one to every SCMI cpufreq policy when that profile is
"low-power".  Other profiles restore each policy's hardware maximum.
"""

from __future__ import annotations

import argparse
import os
from pathlib import Path
import signal
import sys
import time


PROFILE_PATH = Path(
    os.environ.get(
        "SP11_PLATFORM_PROFILE_PATH",
        "/sys/class/platform-profile/platform-profile-0/profile",
    )
)
CPUFREQ_ROOT = Path(
    os.environ.get("SP11_CPUFREQ_ROOT", "/sys/devices/system/cpu/cpufreq")
)
POWER_SAVER_TARGET_KHZ = int(
    os.environ.get("SP11_POWER_SAVER_MAX_KHZ", "2515200")
)
LOW_POWER_PROFILE = "low-power"
PPD_LOW_POWER_PROFILE = "power-saver"
PPD_BUS_NAME = "org.freedesktop.UPower.PowerProfiles"
PPD_OBJECT_PATH = "/org/freedesktop/UPower/PowerProfiles"
PPD_INTERFACE = "org.freedesktop.UPower.PowerProfiles"
DBUS_PROPERTIES_INTERFACE = "org.freedesktop.DBus.Properties"
stop_requested = False


def read_text(path: Path) -> str:
    return path.read_text(encoding="ascii").strip()


def write_and_verify(path: Path, value: int) -> None:
    """Write a cpufreq policy limit and tolerate its asynchronous readback."""
    if int(read_text(path)) == value:
        return
    actual = -1
    for _attempt in range(10):
        with path.open("w", encoding="ascii") as output:
            output.write(f"{value}\n")
        actual = int(read_text(path))
        if actual == value:
            return
        time.sleep(0.05)
    raise RuntimeError(
        f"{path.parent.name}: requested {value} kHz but read back {actual} kHz"
    )


def policies() -> list[Path]:
    result = sorted(
        CPUFREQ_ROOT.glob("policy[0-9]*"),
        key=lambda path: int(path.name.removeprefix("policy")),
    )
    if not result:
        raise RuntimeError(f"no cpufreq policies found under {CPUFREQ_ROOT}")
    return result


def policy_limit(policy: Path, low_power: bool) -> int:
    hardware_max = int(read_text(policy / "cpuinfo_max_freq"))
    if not low_power:
        return hardware_max

    available_path = policy / "scaling_available_frequencies"
    if available_path.exists():
        available = sorted(int(value) for value in read_text(available_path).split())
        candidates = [value for value in available if value <= POWER_SAVER_TARGET_KHZ]
        if not candidates:
            raise RuntimeError(
                f"{policy.name}: no supported frequency at or below "
                f"{POWER_SAVER_TARGET_KHZ} kHz"
            )
        return min(hardware_max, candidates[-1])

    hardware_min = int(read_text(policy / "cpuinfo_min_freq"))
    return max(hardware_min, min(hardware_max, POWER_SAVER_TARGET_KHZ))


def apply(profile: str | None = None) -> None:
    if profile is None:
        profile = read_text(PROFILE_PATH)
    low_power = profile in (LOW_POWER_PROFILE, PPD_LOW_POWER_PROFILE)
    applied: list[str] = []

    for policy in policies():
        limit = policy_limit(policy, low_power)
        minimum = int(read_text(policy / "scaling_min_freq"))
        if minimum > limit:
            raise RuntimeError(
                f"{policy.name}: scaling_min_freq {minimum} exceeds requested "
                f"maximum {limit} kHz"
            )
        maximum_path = policy / "scaling_max_freq"
        write_and_verify(maximum_path, limit)
        actual = int(read_text(maximum_path))
        applied.append(f"{policy.name}={actual}")

    mode = "capped" if low_power else "full-range"
    print(f"profile={profile} mode={mode} " + " ".join(applied), flush=True)


def restore() -> None:
    applied: list[str] = []
    for policy in policies():
        maximum = int(read_text(policy / "cpuinfo_max_freq"))
        write_and_verify(policy / "scaling_max_freq", maximum)
        actual = int(read_text(policy / "scaling_max_freq"))
        applied.append(f"{policy.name}={actual}")
    print("restored " + " ".join(applied), flush=True)


def request_stop(_signum: int, _frame: object) -> None:
    global stop_requested
    stop_requested = True


def watch() -> None:
    import dbus
    from dbus.mainloop.glib import DBusGMainLoop
    from gi.repository import GLib

    DBusGMainLoop(set_as_default=True)
    bus = dbus.SystemBus()
    loop = GLib.MainLoop()

    def active_profile() -> str:
        remote = bus.get_object(PPD_BUS_NAME, PPD_OBJECT_PATH)
        properties = dbus.Interface(remote, DBUS_PROPERTIES_INTERFACE)
        return str(properties.Get(PPD_INTERFACE, "ActiveProfile"))

    def properties_changed(
        _interface: object, changed: object, _invalidated: object
    ) -> None:
        if "ActiveProfile" in changed:
            apply(str(changed["ActiveProfile"]))

    def apply_after_restart() -> bool:
        try:
            apply(active_profile())
        except (dbus.DBusException, OSError, RuntimeError, ValueError) as error:
            print(
                f"sp11-power-profile-cpufreq: restart apply: {error}",
                file=sys.stderr,
                flush=True,
            )
        return GLib.SOURCE_REMOVE

    def name_owner_changed(_name: object, _old_owner: object, new_owner: object) -> None:
        if str(new_owner):
            GLib.timeout_add(100, apply_after_restart)

    def stop_loop(signum: int, frame: object) -> None:
        request_stop(signum, frame)
        loop.quit()

    signal.signal(signal.SIGTERM, stop_loop)
    signal.signal(signal.SIGINT, stop_loop)
    bus.add_signal_receiver(
        properties_changed,
        signal_name="PropertiesChanged",
        dbus_interface=DBUS_PROPERTIES_INTERFACE,
        path=PPD_OBJECT_PATH,
        arg0=PPD_INTERFACE,
    )
    bus.add_signal_receiver(
        name_owner_changed,
        signal_name="NameOwnerChanged",
        dbus_interface="org.freedesktop.DBus",
        path="/org/freedesktop/DBus",
        arg0=PPD_BUS_NAME,
    )
    try:
        apply(active_profile())
        loop.run()
    finally:
        restore()


def main() -> int:
    parser = argparse.ArgumentParser()
    actions = parser.add_mutually_exclusive_group()
    actions.add_argument("--watch", action="store_const", const="watch", dest="action")
    actions.add_argument(
        "--apply-once", action="store_const", const="apply-once", dest="action"
    )
    actions.add_argument(
        "--restore", action="store_const", const="restore", dest="action"
    )
    parser.add_argument("sleep_phase", nargs="?", choices=("pre", "post"))
    parser.add_argument("sleep_operation", nargs="?")
    args = parser.parse_args()

    action = args.sleep_phase or args.action or "watch"

    try:
        if action == "watch":
            watch()
        elif action == "restore":
            restore()
        elif action == "pre":
            return 0
        else:
            apply()
    except (OSError, RuntimeError, ValueError) as error:
        print(f"sp11-power-profile-cpufreq: {error}", file=sys.stderr, flush=True)
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
