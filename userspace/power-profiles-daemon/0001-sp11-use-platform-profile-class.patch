From: SP11 Linux bring-up <sp11-linux@example.invalid>
Subject: [PATCH] platform-profile: use the SP11 class device

The generic kernel platform-profile core can register firmware-agnostic
class devices on device-tree systems. The SP11 has one such device and no
ACPI sysfs hierarchy, so direct the existing backend to that class device.

Also accept the kernel ABI's hyphenated balanced-performance spelling when
the profile is changed outside power-profiles-daemon.
---
 src/ppd-driver-platform-profile.c | 5 +++--
 1 file changed, 3 insertions(+), 2 deletions(-)

diff --git a/src/ppd-driver-platform-profile.c b/src/ppd-driver-platform-profile.c
index 28fc335..fdd620b 100644
--- a/src/ppd-driver-platform-profile.c
+++ b/src/ppd-driver-platform-profile.c
@@ -16,8 +16,8 @@
 #include "ppd-utils.h"
 
 #define LAPMODE_SYSFS_NAME "dytc_lapmode"
-#define ACPI_PLATFORM_PROFILE_PATH "/sys/firmware/acpi/platform_profile"
-#define ACPI_PLATFORM_PROFILE_CHOICES_PATH "/sys/firmware/acpi/platform_profile_choices"
+#define ACPI_PLATFORM_PROFILE_PATH "/sys/class/platform-profile/platform-profile-0/profile"
+#define ACPI_PLATFORM_PROFILE_CHOICES_PATH "/sys/class/platform-profile/platform-profile-0/choices"
 
 struct _PpdDriverPlatformProfile
 {
@@ -89,6 +89,7 @@ acpi_platform_profile_value_to_profile (const char *str)
     return PPD_PROFILE_POWER_SAVER;
 
   if (g_str_equal (str, "balanced") ||
+      g_str_equal (str, "balanced-performance") ||
       g_str_equal (str, "balanced_performance") ||
       g_str_equal (str, "cool"))
     return PPD_PROFILE_BALANCED;
-- 
2.50.1
