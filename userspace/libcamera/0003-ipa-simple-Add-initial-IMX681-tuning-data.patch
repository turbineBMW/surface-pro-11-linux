From 72dc8cff6447792e8d1c0668f3c353eb0740e0db Mon Sep 17 00:00:00 2001
From: turbinebmw <turbine.bmw@gmail.com>
Date: Sun, 12 Jul 2026 20:29:24 +0000
Subject: [PATCH 3/3] ipa: simple: Add initial IMX681 tuning data

Use the measured 10-bit black pedestal on libcamera's 16-bit scale. Keep color correction disabled until a controlled chart measurement can provide a real matrix.
---
 src/ipa/simple/data/imx681.yaml | 16 ++++++++++++++++
 src/ipa/simple/data/meson.build |  1 +
 2 files changed, 17 insertions(+)
 create mode 100644 src/ipa/simple/data/imx681.yaml

diff --git a/src/ipa/simple/data/imx681.yaml b/src/ipa/simple/data/imx681.yaml
new file mode 100644
index 0000000..f2bfac6
--- /dev/null
+++ b/src/ipa/simple/data/imx681.yaml
@@ -0,0 +1,16 @@
+# SPDX-License-Identifier: CC0-1.0
+# SPDX-FileCopyrightText: 2026 turbinebmw
+%YAML 1.1
+---
+version: 1
+algorithms:
+  # The measured black pedestal is 64 at 10 bits. Simple IPA tuning values use
+  # libcamera's 16-bit scale, where 64 << 6 is 4096.
+  - BlackLevel:
+      blackLevel: 4096
+  - Awb:
+  # A color correction matrix must be measured from a controlled chart before
+  # enabling Ccm. The generic identity matrix is not a calibration.
+  - Adjust:
+  - Agc:
+...
diff --git a/src/ipa/simple/data/meson.build b/src/ipa/simple/data/meson.build
index 92795ee..df76092 100644
--- a/src/ipa/simple/data/meson.build
+++ b/src/ipa/simple/data/meson.build
@@ -1,6 +1,7 @@
 # SPDX-License-Identifier: CC0-1.0
 
 conf_files = files([
+    'imx681.yaml',
     'uncalibrated.yaml',
 ])
 
-- 
2.55.0

